package ar.edu.unlp.info.oo2.ejercicio01;

public class Tweet extends Post {

    private String text;

    public Tweet(String text) {
        if (!cumpleCaracteres(text)) {      
            throw new IllegalArgumentException("Texto inválido");
        }
        this.text = text;
    }

    @Override
    public String getText() {
        return this.text;
    }

    private boolean cumpleCaracteres(String text){
        return (text != null | text.length() >= 1 | text.length() <= 280);
    }


}
